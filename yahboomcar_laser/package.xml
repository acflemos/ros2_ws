<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<!--
  package.xml — yahboomcar_laser
  ================================
  Pacote ROS2 de aplicações baseadas em LiDAR para o ROSMaster.
  Contém três modos de operação autónoma com LiDAR:
    1. Avoidance — desvio de obstáculos
    2. Tracker   — seguimento de objetos (PID)
    3. Warning   — aviso sonoro de proximidade

  Dependências de runtime não declaradas:
    - yahboomcar_bringup (sllidar_ros2, ydlidar_ros2_driver — via launch files)
    - numpy, scipy (não declarados)
-->
<package format="3">
  <name>yahboomcar_laser</name>
  <version>0.0.0</version>
  <description>Pacote de aplicações LiDAR para ROSMaster X3/R2: desvio de obstáculos, seguimento de objetos e aviso sonoro de proximidade usando RPLIDAR A1 ou YDLIDAR X4.</description>
  <maintainer email="nx-ros2@todo.todo">nx-ros2</maintainer>
  <license>TODO: License declaration</license>

  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
