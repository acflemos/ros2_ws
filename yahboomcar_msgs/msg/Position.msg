# Posição de um alvo em coordenadas angulares relativas à câmara
# Usado para controlo de pan/tilt ou seguimento de objeto

float32 anglex    # desvio horizontal em graus (negativo=esquerda, positivo=direita)
float32 angley    # desvio vertical em graus (negativo=baixo, positivo=cima)
float32 distance  # distância ao alvo em metros (0.0 se não disponível)
